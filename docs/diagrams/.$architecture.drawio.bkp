          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Celery -> LLM -->
        <mxCell id="e6" value="generate regex&#xa;(cached in Redis)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="celery" target="llm">
