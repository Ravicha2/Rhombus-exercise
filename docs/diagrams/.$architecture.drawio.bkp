          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Redis -> Django (poll) -->
        <mxCell id="e9" value="status / results" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="redis" target="django">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PySpark -> File Storage -->
        <mxCell id="e10" value="write output" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="pyspark" target="filestore">
