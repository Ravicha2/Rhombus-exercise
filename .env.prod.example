# Rhombus Production Deployment
# Copy this to .env.prod and fill in values

# Domain or IP (e.g. "example.com" or "203.0.113.50")
HOST=localhost

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_ALLOWED_HOSTS=*

# Database
DB_NAME=rhombus
DB_USER=postgres
DB_PASSWORD=change-me-to-a-strong-password

# LLM
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Spark (local[*] for single-server, or spark://host:7077 for cluster)
SPARK_MASTER=local[*]